KURGIN_ENVIRONMENT=development
KURGIN_DATABASE_URL=sqlite:///./data/kurgin_auth_mvp.sqlite3

# Local development only. Replace in deployment environment.
KURGIN_JWT_SECRET=CHANGE_ME_IN_ENV_ONLY_MINIMUM_32_CHARS

KURGIN_JWT_ALGORITHM=HS256
KURGIN_JWT_ISSUER=kurgin-api
KURGIN_JWT_AUDIENCE=kurgin-clients
KURGIN_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

KURGIN_ALLOWED_ORIGINS=https://kurgin-website.vercel.app,https://cvdrap.ru,http://localhost:3000,http://127.0.0.1:8000
